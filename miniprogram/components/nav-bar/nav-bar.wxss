/* 导航栏 - iOS 风格 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: rgba(242, 242, 247, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 0.5px solid rgba(0, 0, 0, 0.1);
}

@media (prefers-color-scheme: dark) {
  .nav-bar {
    background-color: rgba(0, 0, 0, 0.85);
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  position: relative;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  letter-spacing: 0.5rpx;
}

.nav-back {
  position: absolute;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 2rpx;
  padding: 8rpx 12rpx 8rpx 0;
}

.back-arrow {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--color-primary);
  line-height: 1;
  margin-top: -2rpx;
}

.back-label {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 400;
}

.nav-placeholder {
  position: absolute;
  right: 32rpx;
  width: 60rpx;
  height: 60rpx;
}

.nav-placeholder-block {
  width: 100%;
}
