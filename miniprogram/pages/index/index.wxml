<!-- 首页 - iOS 风格 -->
<nav-bar title="六了个六" />

<view class="page">
  <!-- 顶部渐变区域 -->
  <view class="hero-gradient">
    <text class="hero-title">粘贴分享链接</text>
    <text class="hero-subtitle">一键解析无水印视频</text>
  </view>

  <!-- 输入卡片 -->
  <view class="ios-section">
    <view class="ios-section-body">
      <textarea
        class="url-input"
        value="{{inputUrl}}"
        placeholder="粘贴抖音/快手/小红书分享链接..."
        placeholder-style="color: #c7c7cc;"
        auto-height
        maxlength="500"
        bindinput="onInput"
        confirm-type="done"
        cursor-spacing="20"
      />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <view class="ios-btn secondary" bindtap="onPaste">
      <text>从剪贴板粘贴</text>
    </view>
    <view class="ios-btn secondary" bindtap="onClear" wx:if="{{inputUrl}}">
      <text>清空</text>
    </view>
  </view>

  <!-- 解析按钮 -->
  <view class="parse-section">
    <button
      class="parse-btn btn-gradient {{canParse ? '' : 'disabled'}}"
      bindtap="onParse"
      disabled="{{!canParse || parsing}}"
      loading="{{parsing}}"
    >
      <text wx:if="{{!parsing}}">解析</text>
      <text wx:else>解析中</text>
    </button>
  </view>

  <!-- 配额 -->
  <view class="quota-info">
    <text class="quota-text">今日剩余 <text class="quota-num">{{remainingQuota}}</text> 次</text>
  </view>

  <!-- 支持平台 -->
  <view class="platform-tags-section">
    <text class="platform-tags-label">支持平台</text>
    <view class="platform-tags">
      <view class="platform-tag">抖音</view>
      <view class="platform-tag">快手</view>
      <view class="platform-tag">小红书</view>
      <view class="platform-tag">TikTok</view>
    </view>
  </view>

  <!-- 使用提示 -->
  <view class="tips-line">
    <text>使用提示：复制分享链接 → 粘贴 → 解析</text>
  </view>

  <!-- 广告 -->
  <view class="ad-hint" wx:if="{{showAdHint}}">
    <text class="ad-hint-text">观看广告获取更多解析次数</text>
  </view>
</view>
