/* 首页 - iOS 风格 */
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部渐变 */
.hero-gradient {
  padding: 48rpx 40rpx 32rpx;
  background: linear-gradient(180deg, rgba(0, 122, 255, 0.06) 0%, transparent 100%);
  text-align: center;
  flex-shrink: 0;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 输入区域 */
.url-input {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.6;
  box-sizing: border-box;
  background: transparent;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  flex-shrink: 0;
}

.ios-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
}

.ios-btn.secondary {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  border: 1rpx solid var(--color-border);
}

.ios-btn.secondary:active {
  background-color: var(--color-cell-highlight);
}

/* 解析按钮 */
.parse-section {
  padding: 16rpx 32rpx;
  flex-shrink: 0;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

.parse-btn.disabled {
  background: var(--color-border);
  color: var(--color-text-muted);
  box-shadow: none;
}

/* 配额 */
.quota-info {
  text-align: center;
  padding: 16rpx 0;
  flex-shrink: 0;
}

.quota-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.quota-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* 支持平台标签 */
.platform-tags-section {
  margin: 24rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.platform-tags-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.platform-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.platform-tag {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--color-primary);
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
}

/* 弹性占位 - 把剩余内容推到底部 */
.spacer {
  flex: 1;
  min-height: 20rpx;
}

/* 使用提示 */
.tips-line {
  margin: 0 32rpx 24rpx;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

/* 广告 */
.ad-hint {
  margin: 0 32rpx 32rpx;
  padding: 24rpx;
  text-align: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-primary);
  flex-shrink: 0;
}

.ad-hint-text {
  font-size: 26rpx;
  color: var(--color-primary);
}
