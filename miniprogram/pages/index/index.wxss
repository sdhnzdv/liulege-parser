/* 首页 - iOS 风格 */
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 顶部渐变 */
.hero-gradient {
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, rgba(0, 122, 255, 0.06) 0%, transparent 100%);
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 输入区域 */
.url-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.6;
  box-sizing: border-box;
  background: transparent;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
}

.ios-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
}

.ios-btn.secondary {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  border: 1rpx solid var(--color-border);
}

.ios-btn.secondary:active {
  background-color: var(--color-cell-highlight);
}

/* 解析按钮 */
.parse-section {
  padding: 16rpx 32rpx;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

.parse-btn.disabled {
  background: var(--color-border);
  color: var(--color-text-muted);
  box-shadow: none;
}

/* 配额 */
.quota-info {
  text-align: center;
  padding: 20rpx 0;
}

.quota-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.quota-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* iOS 列表项 */
.cell-label {
  font-size: 30rpx;
  color: var(--color-text);
}

.cell-value {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 广告 */
.ad-hint {
  margin: 32rpx 32rpx;
  padding: 24rpx;
  text-align: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-primary);
}

.ad-hint-text {
  font-size: 26rpx;
  color: var(--color-primary);
}
