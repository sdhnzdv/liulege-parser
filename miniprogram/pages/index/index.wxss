/* 首页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Hero 区域 */
.hero-section {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border-radius: 40rpx;
  margin-bottom: 24rpx;
}

.hero-badge text {
  font-size: 24rpx;
  color: var(--color-primary);
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 输入区域 */
.input-area {
  position: relative;
}

.platform-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: rgba(16, 185, 129, 0.1);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.platform-badge text {
  font-size: 24rpx;
  color: var(--color-success);
}

.url-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background-color: var(--color-border-light);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  border: 1rpx solid var(--color-border);
}

.paste-btn {
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.clear-btn {
  color: var(--color-text-muted);
  border-color: var(--color-border);
}

/* 解析按钮 */
.parse-section {
  padding: 24rpx 24rpx;
}

.parse-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
}

.parse-btn.disabled {
  background: var(--color-border);
  color: var(--color-text-muted);
  box-shadow: none;
}

.parse-btn::after {
  border: none;
}

/* 配额栏 */
.quota-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.quota-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 0 4rpx;
}

.quota-total {
  color: var(--color-text-muted);
}

/* 平台列表 */
.platform-list {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  padding: 32rpx 0;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.platform-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.platform-icon.douyin { background-color: rgba(0, 0, 0, 0.06); }
.platform-icon.kuaishou { background-color: rgba(255, 73, 1, 0.08); }
.platform-icon.xiaohongshu { background-color: rgba(255, 36, 66, 0.08); }

/* 提示 */
.tips-section {
  margin: 16rpx 24rpx;
  padding: 28rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.tips-list text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 2;
}

/* 广告 */
.ad-placeholder {
  margin: 32rpx 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.06), rgba(139, 92, 246, 0.06));
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-primary);
  text-align: center;
}

.ad-text {
  font-size: 26rpx;
  color: var(--color-primary);
}
