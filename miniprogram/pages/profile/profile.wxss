/* 个人中心页 - iOS 风格 */
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 用户区域 */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 40rpx;
  background: linear-gradient(180deg, rgba(0, 122, 255, 0.04) 0%, transparent 100%);
  flex-shrink: 0;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  width: 120rpx;
  height: 120rpx;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--color-border-light);
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.1), rgba(88, 86, 214, 0.1));
}

.avatar-emoji {
  font-size: 56rpx;
}

.nickname-input {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  width: 400rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.user-id {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 配额行 */
.quota-row {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}

.quota-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.quota-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.quota-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.quota-divider {
  width: 1rpx;
  height: 48rpx;
  background-color: var(--color-separator);
}

/* 菜单 */
.cell-label {
  font-size: 32rpx;
  color: var(--color-text);
}

/* 箭头 */
.cell-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}

/* 版本 */
.version-text {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: auto;
}
