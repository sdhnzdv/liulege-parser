<!-- 个人中心页 - iOS 风格 -->
<nav-bar title="我的" />

<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <image
      wx:if="{{userInfo && userInfo.avatarUrl}}"
      class="user-avatar"
      src="{{userInfo.avatarUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="user-avatar default-avatar">
      <text class="avatar-emoji">😊</text>
    </view>
    <text class="user-name">{{userInfo ? userInfo.nickName : '微信用户'}}</text>
    <text class="user-id">ID: {{openid ? openid.substring(0, 12) + '...' : '未登录'}}</text>
  </view>

  <!-- 配额 -->
  <view class="ios-section">
    <view class="ios-section-body">
      <view class="quota-row">
        <view class="quota-item">
          <text class="quota-num">{{quota.remaining}}</text>
          <text class="quota-label">今日剩余</text>
        </view>
        <view class="quota-divider"></view>
        <view class="quota-item">
          <text class="quota-num">{{quota.used}}</text>
          <text class="quota-label">已使用</text>
        </view>
        <view class="quota-divider"></view>
        <view class="quota-item">
          <text class="quota-num">{{totalParsed}}</text>
          <text class="quota-label">累计解析</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="ios-section">
    <view class="ios-section-body">
      <view class="ios-cell" bindtap="onGoHistory">
        <text class="cell-label">解析历史</text>
        <text class="cell-arrow">›</text>
      </view>
      <view class="ios-cell" bindtap="onClearCache">
        <text class="cell-label">清除缓存</text>
        <text class="cell-arrow">›</text>
      </view>
      <view class="ios-cell" bindtap="onFeedback">
        <text class="cell-label">意见反馈</text>
        <text class="cell-arrow">›</text>
      </view>
      <view class="ios-cell" bindtap="onAbout">
        <text class="cell-label">关于</text>
        <text class="cell-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本 -->
  <view class="version-text">
    <text>六了个六解析助手 v1.0.0</text>
  </view>
</view>
