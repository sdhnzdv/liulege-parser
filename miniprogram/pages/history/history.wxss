/* 历史记录页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.history-list {
  padding: 16rpx 0;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin: 8rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  gap: 16rpx;
}

.history-item:active {
  opacity: 0.8;
}

.history-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background-color: var(--color-border-light);
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  overflow: hidden;
}

.history-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-platform {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(99, 102, 241, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.history-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
}
