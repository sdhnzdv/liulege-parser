/* 历史记录页 - iOS 风格 */
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.history-cell {
  gap: 20rpx;
  padding: 20rpx 32rpx;
}

.history-cover {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background-color: var(--color-border-light);
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.history-title {
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.3;
}

.history-meta {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.cell-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}
