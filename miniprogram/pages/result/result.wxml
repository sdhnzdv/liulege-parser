<!-- 结果页 - iOS 风格 -->
<nav-bar title="解析结果" showBack="{{true}}" />

<view class="page" wx:if="{{result}}">
  <!-- 封面预览 -->
  <view class="cover-section">
    <image
      wx:if="{{result.cover}}"
      class="cover-image"
      src="{{result.cover}}"
      mode="aspectFill"
      bindtap="onPreviewMedia"
    />
    <view class="cover-overlay" wx:if="{{result.type === 'video'}}" bindtap="onDownloadVideo">
      <view class="play-circle">
        <text class="play-icon">▶</text>
      </view>
    </view>
  </view>

  <!-- 标题 -->
  <view class="ios-section">
    <view class="ios-section-body">
      <view class="text-cell">
        <text class="text-cell-content">{{result.title || '暂无标题'}}</text>
        <view class="copy-tap" bindtap="onCopyText" data-text="{{result.title}}">
          <text class="copy-tap-text">拷贝</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 作者 -->
  <view class="ios-section">
    <view class="ios-section-header">作者</view>
    <view class="ios-section-body">
      <view class="ios-cell">
        <image wx:if="{{result.authorAvatar}}" class="cell-avatar" src="{{result.authorAvatar}}" mode="aspectFill" />
        <view class="cell-content">
          <text class="cell-label">{{result.author || '未知'}}</text>
          <text class="cell-desc" wx:if="{{result.authorUid}}">@{{result.authorUid}}</text>
        </view>
        <view class="copy-tap" bindtap="onCopyText" data-text="{{result.author}}">
          <text class="copy-tap-text">拷贝</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 文案 -->
  <view class="ios-section">
    <view class="ios-section-header">文案</view>
    <view class="ios-section-body">
      <view class="text-cell">
        <text class="text-cell-content secondary">{{result.description || '暂无文案'}}</text>
        <view class="copy-tap" bindtap="onCopyText" data-text="{{result.description}}">
          <text class="copy-tap-text">拷贝</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 视频信息 -->
  <view class="ios-section">
    <view class="ios-section-header">信息</view>
    <view class="ios-section-body">
      <view class="ios-cell" wx:if="{{result.duration}}">
        <text class="cell-label">时长</text>
        <text class="cell-value">{{result.duration}}</text>
      </view>
      <view class="ios-cell" wx:if="{{result.musicName}}">
        <text class="cell-label">音乐</text>
        <text class="cell-value text-ellipsis">{{result.musicName}}</text>
      </view>
      <view class="ios-cell">
        <text class="cell-label">平台</text>
        <text class="cell-value">{{platformName || '未知'}}</text>
      </view>
    </view>
  </view>

  <!-- 下载按钮 -->
  <view class="download-section">
    <button class="download-btn btn-gradient" bindtap="onDownloadVideo">
      <text>下载无水印视频</text>
    </button>
  </view>

  <!-- 返回首页 -->
  <view class="back-section" bindtap="onGoHome">
    <text class="back-text">返回首页</text>
  </view>
</view>

<loading show="{{loading}}" text="加载中..." />

<empty-state
  wx:if="{{!result && !loading}}"
  icon=""
  title="暂无数据"
  desc="返回首页重新解析"
  showBtn="{{true}}"
  btnText="返回首页"
  bind:btnclick="onGoHome"
/>
