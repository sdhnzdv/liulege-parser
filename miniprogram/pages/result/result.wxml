<!-- 解析结果页 -->
<nav-bar title="解析结果" showBack="{{true}}" />

<view class="page" wx:if="{{result}}">
  <!-- 媒体预览区 -->
  <view class="media-preview">
    <!-- 视频封面/图片 -->
    <image
      wx:if="{{result.cover}}"
      class="cover-image"
      src="{{result.cover}}"
      mode="aspectFill"
      bindtap="onPreviewMedia"
    />
    <!-- 视频播放按钮 -->
    <view class="play-btn" wx:if="{{result.type === 'video'}}" bindtap="onPreviewVideo">
      <text class="play-icon">▶</text>
    </view>
    <!-- 类型标签 -->
    <view class="type-tag {{result.type}}">
      <text>{{result.type === 'video' ? '视频' : '图片'}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <card title="📝 基本信息" tag="{{platformName}}">
    <view class="info-list">
      <view class="info-item" wx:if="{{result.title}}">
        <text class="info-label">标题</text>
        <text class="info-value">{{result.title}}</text>
      </view>
      <view class="info-item" wx:if="{{result.author}}">
        <text class="info-label">作者</text>
        <view class="author-row">
          <image wx:if="{{result.authorAvatar}}" class="author-avatar" src="{{result.authorAvatar}}" mode="aspectFill" />
          <text class="info-value">{{result.author}}</text>
        </view>
      </view>
      <view class="info-item" wx:if="{{result.description}}">
        <text class="info-label">描述</text>
        <text class="info-value desc-text">{{result.description}}</text>
      </view>
    </view>
  </card>

  <!-- 下载区域 -->
  <card title="⬇️ 下载链接" shadow="{{true}}">
    <view class="download-section">
      <!-- 无水印直链 -->
      <view class="link-row">
        <text class="link-label">无水印直链</text>
        <view class="link-actions">
          <view class="link-btn copy-btn" bindtap="onCopyLink">
            <text>📋 复制</text>
          </view>
        </view>
      </view>
      <view class="link-url text-ellipsis">
        <text>{{result.mediaUrl || '暂无'}}</text>
      </view>

      <!-- 下载按钮组 -->
      <view class="download-btns">
        <button
          wx:if="{{result.type === 'video'}}"
          class="download-btn primary"
          bindtap="onDownloadVideo"
        >
          <text>📥 下载视频</text>
        </button>
        <button
          wx:if="{{result.type === 'image' || result.cover}}"
          class="download-btn secondary"
          bindtap="onDownloadCover"
        >
          <text>🖼️ 下载封面</text>
        </button>
      </view>
    </view>
  </card>

  <!-- 操作提示 -->
  <view class="action-hint">
    <text>💡 长按封面图可保存到相册</text>
  </view>
</view>

<loading show="{{loading}}" text="加载中..." />

<empty-state
  wx:if="{{!result && !loading}}"
  icon="🔍"
  title="暂无数据"
  desc="返回首页重新解析"
  showBtn="{{true}}"
  btnText="返回首页"
  bind:btnclick="onGoHome"
/>
