/* 结果页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 媒体预览 */
.media-preview {
  position: relative;
  margin: 24rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background-color: #000;
}

.cover-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.play-icon {
  font-size: 40rpx;
  color: #fff;
  margin-left: 6rpx;
}

.type-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  backdrop-filter: blur(20rpx);
}

.type-tag.video { background-color: rgba(99, 102, 241, 0.7); }
.type-tag.image { background-color: rgba(16, 185, 129, 0.7); }

/* 文本区域 */
.text-section {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.text-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  word-break: break-all;
}

.desc-text {
  color: var(--color-text-secondary);
}

/* 复制按钮 */
.copy-icon {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-icon-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.copy-icon:active {
  background-color: var(--color-border-light);
}

/* 作者区域 */
.author-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
}

.author-uid {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text);
}

/* 下载区域 */
.download-area {
  margin: 32rpx 24rpx;
}

.download-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.download-btn::after {
  border: none;
}

.download-btn.primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(99, 102, 241, 0.3);
}

/* 返回首页 */
.back-home-section {
  margin: 0 24rpx 40rpx;
  padding: 24rpx 0;
  text-align: center;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
}

.back-home-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}
