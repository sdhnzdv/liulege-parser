/* 结果页 - iOS 风格 */
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 封面 */
.cover-section {
  position: relative;
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: #000;
}

.cover-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.15);
}

.play-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  font-size: 36rpx;
  color: #007aff;
  margin-left: 4rpx;
}

/* 文本卡片 */
.text-cell {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-card);
}

.text-cell-content {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.6;
}

.text-cell-content.secondary {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

/* 拷贝按钮 */
.copy-tap {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--color-border);
  align-self: flex-start;
  margin-top: 4rpx;
}

.copy-tap:active {
  background-color: var(--color-cell-highlight);
}

.copy-tap-text {
  font-size: 22rpx;
  color: var(--color-primary);
}

/* 作者头像 */
.cell-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cell-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.cell-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 下载按钮 */
.download-section {
  padding: 32rpx 32rpx 16rpx;
}

.download-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

/* 返回首页 */
.back-section {
  margin: 0 32rpx;
  padding: 24rpx 0;
  text-align: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.back-section:active {
  background-color: var(--color-cell-highlight);
}

.back-text {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 500;
}
